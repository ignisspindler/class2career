<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Why PhDs and Scientists Need This Course | Class2Career</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
    <style>
        :root {
            --deep-navy: #0A1628;
            --rich-navy: #1A365D;
            --gold: #C9A227;
            --soft-gold: #E8D5A3;
            --coral: #FF6B6B;
            --emerald: #10B981;
            --slate: #64748B;
            --off-white: #F8FAFC;
            --white: #FFFFFF;
            --light-gray: #E2E8F0;
            --dark-gray: #334155;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            font-size: 18px;
            line-height: 1.8;
            color: var(--dark-gray);
            background: var(--white);
        }

        nav {
            background: var(--deep-navy);
            padding: 1rem 2rem;
            text-align: center;
        }

        nav a {
            color: var(--gold);
            text-decoration: none;
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 600;
            font-size: 1.25rem;
        }

        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 3rem 2rem;
        }

        h1 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--deep-navy);
            line-height: 1.2;
            margin-bottom: 2rem;
        }

        h2 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--deep-navy);
            margin: 3rem 0 1.5rem;
        }

        .subtitle {
            font-family: 'Crimson Pro', serif;
            font-size: 1.25rem;
            color: var(--slate);
            font-style: italic;
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 2px solid var(--light-gray);
        }

        p {
            margin-bottom: 1.5rem;
        }

        blockquote {
            font-family: 'Crimson Pro', serif;
            font-size: 1.5rem;
            font-style: italic;
            color: var(--rich-navy);
            border-left: 4px solid var(--gold);
            padding-left: 1.5rem;
            margin: 2rem 0;
        }

        .story-box {
            background: var(--off-white);
            padding: 2rem;
            border-radius: 8px;
            margin: 2rem 0;
            border-left: 4px solid var(--gold);
        }

        .story-box p:last-child {
            margin-bottom: 0;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .stat {
            text-align: center;
            padding: 1.5rem;
            background: var(--deep-navy);
            border-radius: 8px;
        }

        .stat .number {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--gold);
        }

        .stat .label {
            color: var(--soft-gold);
            font-size: 0.875rem;
        }

        ul {
            margin: 1.5rem 0;
            padding-left: 1.5rem;
        }

        li {
            margin-bottom: 0.75rem;
        }

        .workbook-list {
            list-style: none;
            padding: 0;
            margin: 2rem 0;
        }

        .workbook-list li {
            background: var(--off-white);
            padding: 1.25rem 1.5rem;
            margin-bottom: 1rem;
            border-radius: 8px;
            border-left: 4px solid var(--gold);
        }

        .workbook-list strong {
            color: var(--deep-navy);
            display: block;
            margin-bottom: 0.25rem;
        }

        .cta-box {
            background: var(--deep-navy);
            color: var(--white);
            padding: 2.5rem;
            border-radius: 8px;
            text-align: center;
            margin: 3rem 0;
        }

        .cta-box .price {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            color: var(--gold);
            margin-bottom: 0.5rem;
        }

        .cta-box p {
            color: var(--soft-gold);
            margin-bottom: 1.5rem;
        }

        .btn {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: var(--gold);
            color: var(--deep-navy);
            font-family: 'Bricolage Grotesque', sans-serif;
            font-weight: 600;
            font-size: 1.125rem;
            text-decoration: none;
            border-radius: 6px;
            transition: all 0.3s;
        }

        .btn:hover {
            background: var(--soft-gold);
            transform: translateY(-2px);
        }

        .signature {
            font-family: 'Crimson Pro', serif;
            font-style: italic;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid var(--light-gray);
        }

        .signature strong {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-style: normal;
            display: block;
            color: var(--deep-navy);
        }

        footer {
            background: var(--off-white);
            padding: 2rem;
            text-align: center;
            font-size: 0.875rem;
            color: var(--slate);
        }

        footer a {
            color: var(--gold);
            text-decoration: none;
        }

        @media (max-width: 600px) {
            .stats {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
